{
  "name": "command-cc",
  "version": "0.9.0",
  "private": false,
  "description": "Local wrappers that route your installed Claude Code CLI to Command Code Go-plan models or Kiro Gateway.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sioaeko/command-cc.git"
  },
  "homepage": "https://github.com/sioaeko/command-cc#readme",
  "bugs": {
    "url": "https://github.com/sioaeko/command-cc/issues"
  },
  "bin": {
    "command-cc": "./bin/command-claudecode.mjs",
    "command-claudecode": "./bin/command-claudecode.mjs",
    "claude-command-code": "./bin/command-claudecode.mjs",
    "cmdclaude": "./bin/command-claudecode.mjs",
    "ccclaude": "./bin/command-claudecode.mjs",
    "kiro-cc": "./bin/kiro-cc.mjs"
  },
  "files": [
    "bin",
    "assets",
    "README.md"
  ],
  "scripts": {
    "setup": "node ./bin/command-claudecode.mjs setup",
    "models": "node ./bin/command-claudecode.mjs models",
    "doctor": "node ./bin/command-claudecode.mjs doctor",
    "kiro:models": "node ./bin/kiro-cc.mjs models",
    "kiro:doctor": "node ./bin/kiro-cc.mjs doctor",
    "help": "node ./bin/command-claudecode.mjs --help",
    "pack:check": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
